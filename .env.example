# SUP Platform — környezeti változók MINTÁJA (F1.1, 4. fejezet).
# Másold `.env`-be és töltsd ki. TITKOT IDE NE ÍRJ, és a valódi .env-et
# soha ne kommiteld. A VITE_ prefixű értékek PUBLIKUSAK (a kliens-bundle-be
# is bekerülnek) — csak olyasmi kaphat VITE_ prefixet, ami eleve nyilvános.

# Supabase projekt-URL (publikus). Supabase → Project Settings → Data API.
VITE_SUPABASE_URL=

# Supabase PUBLISHABLE API-kulcs (sb_publishable_..., publikus — RLS mögött
# érvényesül). Supabase → Project Settings → API Keys → Publishable key.
# A legacy `anon` JWT-kulcs helyett EZT használjuk (a Supabase is ezt ajánlja).
# FIGYELEM: a SECRET kulcs (sb_secret_..., a legacy `service_role` utódja)
# TITOK — ide SOHA nem kerülhet; ha privilegizált hozzáférés kell (Edge
# Function), azt a Supabase Edge Function secrets-ben tároljuk.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Cloudflare Turnstile SITE key (publikus). Ha üresen hagyod, a captcha
# fejlesztői módban kikapcsol, a formok használhatók maradnak.
# A Turnstile SECRET kulcs NEM ide való: azt a Supabase Dashboardban
# (Auth → Attack Protection / CAPTCHA) kell beállítani — a secret-oldali
# verifikációt a Supabase Auth végzi a signUp/signIn hívások captcha-tokenjén.
VITE_TURNSTILE_SITE_KEY=
