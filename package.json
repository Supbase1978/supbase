{
  "name": "sup-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build:web": "react-router build",
    "build:native": "cross-env BUILD_TARGET=native react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
